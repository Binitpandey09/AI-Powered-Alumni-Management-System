# ── Django ────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-in-production
DJANGO_SETTINGS_MODULE=alumni_platform.settings.dev

# ── Database ──────────────────────────────────────────────────
DB_NAME=alumni_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Production only (overrides above)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email ─────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── AI APIs ───────────────────────────────────────────────────
# Gemini API (fallback resume parsing + AI summary)
GEMINI_API_KEY=your_gemini_key_here

# Affinda API (primary resume parsing)
AFFINDA_API_KEY=your_affinda_key_here
AFFINDA_WORKSPACE_ID=your_workspace_id_here
OPENAI_API_KEY=your_openai_api_key

# ── Production only ───────────────────────────────────────────
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
