# ── AlumniAI Production Environment Variables ─────────────────
# Copy this file to .env on your production server and fill in real values.
# NEVER commit the actual .env file to version control.

# ── Django Core ───────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=alumni_platform.settings.prod
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ──────────────────────────────────────────────────
# Option A: Use DATABASE_URL (Render, Railway, Heroku set this automatically)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B: Individual fields (used if DATABASE_URL is not set)
DB_NAME=alumniai_db
DB_USER=alumniai_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
# Used for Celery broker, result backend, cache, and WebSocket channel layer
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── AI Services ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Payments ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── Render.com (auto-set by Render, do not change) ────────────
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
